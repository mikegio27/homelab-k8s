        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (code) (rate(http_requests_received_total{namespace=\"jellyfin\"}[$__rate_interval]))", "legendFormat": "{{code}}", "refId": "A" }
      ],
      "title": "Request Rate by Status Code",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
