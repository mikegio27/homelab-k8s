      ],
      "title": "Top Endpoints by Request Rate",
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "Value": false }, "indexByName": {}, "renameByName": { "Value": "req/s", "endpoint": "Endpoint", "method": "Method" } } }
